{
  "name": "vlinders-api",
  "version": "1.0.0",
  "description": "Production-grade AI API server for Vlinder Chat - Copilot API compatible",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "build": "tsc"
  },
  "keywords": [
    "ai",
    "api",
    "cloudflare-workers",
    "hono",
    "openai",
    "anthropic",
    "copilot",
    "production"
  ],
  "author": "QuickerStudio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/QuickerStudio/Vlinders-API.git"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "@hono/zod-validator": "^0.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240000.0",
    "@types/node": "^20.11.0",
    "wrangler": "^3.28.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "prettier": "^3.2.0"
  }
}
